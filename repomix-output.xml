import { useEffect, useState } from 'react';
import API from '../api/axiosInstance';

const Profile = () => {
  const [profile, setProfile] = useState({ name: '', company_name: '', email: '' });
  const [loading, setLoading] = useState(true);

  // Load profile on mount
  useEffect(() => {
    const fetchProfile = async () => {
      try {
        // Headers are automatically attached by axiosInstance.js
        const { data } = await API.get('/auth/profile');
        setProfile(data);
        setLoading(false);
      } catch (err) {
        console.error("Error fetching profile", err);
      }
    };
    fetchProfile();
  }, []);

  const handleUpdate = async (e) => {
    e.preventDefault();
    try {
      await API.put('/auth/profile', { 
        name: profile.name, 
        company_name: profile.company_name 
      });
      alert("Profile Updated!");
    } catch  {
      alert("Update failed");
    }
  };

  if (loading) return <p>Loading...</p>;

  return (
    <div style={{ padding: '2rem' }}>
      <h2>Your Profile</h2>
      <p>Email: {profile.email} (Cannot be changed)</p>
      <form onSubmit={handleUpdate} style={{ display: 'flex', flexDirection: 'column', gap: '10px', maxWidth: '300px' }}>
        <label>Name:</label>
        <input value={profile.name} onChange={e => setProfile({...profile, name: e.target.value})} />
        
        <label>Company:</label>
        <input value={profile.company_name} onChange={e => setProfile({...profile, company_name: e.target.value})} />
        
        <button type="submit">Update Profile</button>
      </form>
    </div>
  );
};

export default Profile;
</file>

